# Shared script configuration template
# Copy to config.env and customize values as needed.

# Comma-separated build targets (supported: linux,darwin,windows)
# You can still set a single TARGET for backwards compatibility.
TARGETS="linux"
# TARGET="linux"

# Comma-separated plugin formats (supported: vst3,clap3,au)
# 'au' is darwin-only and will be skipped for non-darwin targets.
FORMATS="vst3"
# FORMAT="vst3"

BUILD_PROFILE="release"

# Optional rust target triples for cross-compilation.
# Leave empty to build for host toolchain target.
TARGET_TRIPLE_LINUX=""
TARGET_TRIPLE_DARWIN=""
TARGET_TRIPLE_WINDOWS=""

# Local build output base; scripts append /vst3, /clap, /au by format
BUILD_PATH="target"

# Install destinations by target+format
VST3_INSTALL_PATH_LINUX="$HOME/.vst3"
CLAP_INSTALL_PATH_LINUX="$HOME/.clap"

VST3_INSTALL_PATH_DARWIN="$HOME/Library/Audio/Plug-Ins/VST3"
CLAP_INSTALL_PATH_DARWIN="$HOME/Library/Audio/Plug-Ins/CLAP"
AU_INSTALL_PATH_DARWIN="$HOME/Library/Audio/Plug-Ins/Components"

VST3_INSTALL_PATH_WINDOWS="$HOME/AppData/Local/Common Files/VST3"
CLAP_INSTALL_PATH_WINDOWS="$HOME/.clap"
