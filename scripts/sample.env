# Shared script configuration template
# Copy to config.env and customize values as needed.

TARGET="linux"
PLUGIN_NAME="Kick Plugin"
PLUGIN_BINARY_NAME="libkick_plugin.so"
BUILD_PROFILE="release"
TARGET_ARCH_DIR="x86_64-linux"

# Local build output used for bundling and Carla preview
LOCAL_VST3_RELATIVE_PATH="target/vst3"

# Installed plugin destination
VST_INSTALL_PATH="$HOME/.vst3"
