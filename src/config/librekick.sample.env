# LibreKick UI config template
# Copy to librekick.env and adjust values as needed.

# Editor window
BASE_EDITOR_WIDTH=980
BASE_EDITOR_HEIGHT=560
MIN_EDITOR_WIDTH=520
MIN_EDITOR_HEIGHT=320

# Envelope timing
NOTE_LENGTH_MAX_MS=1000

# Tuning
DEFAULT_TUNING_A4_HZ=432

# Waveform zoom
WAVEFORM_ZOOM_MIN_PERCENT=1
WAVEFORM_ZOOM_MAX_PERCENT=200
WAVEFORM_ZOOM_STEP_PERCENT=5

# Patch storage (optional override)
# Linux default: ~/.config/LibreKick/patches
# macOS default: ~/Library/Application Support/LibreKick/patches
# Windows default: %APPDATA%/LibreKick/patches
# PATCHES_DIR=~/.config/LibreKick/patches
